# TrustLens Backend — Environment Variables
# Copy this file to .env and adjust for local development.

# Application
APP_NAME=TrustLens
APP_ENV=development
DEBUG=true

# Server
HOST=127.0.0.1
PORT=8000

# CORS (comma-separated origins allowed to call the API)
# Use "*" during extension development before you know the extension ID.
CORS_ORIGINS=*,chrome-extension://YOUR_EXTENSION_ID,http://localhost:3000

# Verification mode: mock | gemini (gemini not available in MVP)
VERIFICATION_MODE=mock

# Future: Gemini API (Phase 2 — do not configure for MVP)
# GEMINI_API_KEY=
