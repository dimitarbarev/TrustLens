{
  "name": "trustlens-extension",
  "displayName": "TrustLens",
  "version": "0.1.0",
  "description": "Check suspicious posts, charts, and screenshots before you share.",
  "author": "TrustLens Contributors",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "0.0.287",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.16",
    "typescript": "5.7.2"
  },
  "manifest": {
    "host_permissions": [
      "http://127.0.0.1:8000/*",
      "http://localhost:8000/*"
    ],
    "permissions": [
      "storage",
      "contextMenus"
    ]
  }
}
